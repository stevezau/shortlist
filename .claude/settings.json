{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(ruff check *)",
      "Bash(ruff format *)",
      "Bash(pytest *)",
      "Bash(pip install *)",
      "Bash(python -m *)",
      "Bash(pnpm install*)",
      "Bash(pnpm -C web *)",
      "Bash(pnpm run *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(alembic *)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(./config/**)",
      "Read(CLAUDE.local.md)"
    ]
  }
}
